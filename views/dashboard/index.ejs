<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            margin: 0;
            padding: 0;
        }
        .dashboard-container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
        }
        .welcome-header {
            margin-bottom: 30px;
        }
        .welcome-header h1 {
            font-size: 28px;
            color: #1a1a2e;
            margin: 0;
        }
        .welcome-header p {
            color: #666;
            margin: 6px 0 0;
        }
        .cards {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .card {
            background: #fff;
            border-radius: 12px;
            padding: 28px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.07);
        }
        .card h2 {
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #999;
            margin: 0 0 16px;
        }
        .card .value {
            font-size: 32px;
            font-weight: bold;
            color: #1a1a2e;
        }
        .card .label {
            font-size: 13px;
            color: #aaa;
            margin-top: 4px;
        }
        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #f0f0f0;
            font-size: 14px;
        }
        .info-row:last-child { border-bottom: none; }
        .info-row .key { color: #888; }
        .info-row .val { color: #1a1a2e; font-weight: 500; }
        .wallet-id {
            font-size: 12px;
            color: #bbb;
            word-break: break-all;
            margin-top: 12px;
        }
        .no-wallet {
            color: #e57373;
            font-size: 14px;
        }
        nav a { margin-right: 14px; }
    </style>
</head>
<body>
    <%- include('../includes/nav') %>

    <div class="dashboard-container">
        <div class="welcome-header">
            <h1>Welcome back, <%= user.name %> 👋</h1>
            <p><%= user.email %></p>
        </div>

        <div class="cards">
            <!-- Wallet Balance Card -->
            <div class="card">
                <h2>Wallet Balance</h2>
                <% if (wallet) { %>
                    <div class="value">
                        <%= parseFloat(wallet.balance).toFixed(2) %>
                        <span style="font-size:16px;color:#888;"> <%= wallet.currency %></span>
                    </div>
                    <div class="label">Available balance</div>
                    <div class="wallet-id">Wallet ID: <%= wallet.wallet_id %></div>
                <% } else { %>
                    <p class="no-wallet">No wallet found for your account.</p>
                <% } %>
            </div>

            <!-- Account Info Card -->
            <div class="card">
                <h2>Account Info</h2>
                <div class="info-row">
                    <span class="key">Name</span>
                    <span class="val"><%= user.name %></span>
                </div>
                <div class="info-row">
                    <span class="key">Email</span>
                    <span class="val"><%= user.email %></span>
                </div>
                <% if (wallet) { %>
                <div class="info-row">
                    <span class="key">Currency</span>
                    <span class="val"><%= wallet.currency %></span>
                </div>
                <div class="info-row">
                    <span class="key">Wallet Since</span>
                    <span class="val"><%= new Date(wallet.created_at).toLocaleDateString() %></span>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
